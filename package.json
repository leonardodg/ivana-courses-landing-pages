{
  "name": "courses-landing-pages",
  "version": "1.0.0",
  "description": "Website Landing Pages - Ivana Academy by LeoDG",
  "main": "index.js",
  "scripts": {
    "clean": "del-cli --force public",
    "copy:html": "copyfiles -u 1 \"src/*.html\" public && copyfiles -u 1 \"src/**/index.html\" public",
    "copy:img": "copyfiles -u 2 \"src/images/**/*\" public/img",
    "copy:fonts": "copyfiles -u 4 \"node_modules/@fortawesome/fontawesome-free/webfonts/*\" public/webfonts && copyfiles -u 3 \"node_modules/material-icons/iconfont/*\" public/material-icons",
    "copy:fa-css": "copyfiles -u 4 \"node_modules/@fortawesome/fontawesome-free/css/all.min.css\" public/css",
    "build:css-velas": "npx @tailwindcss/cli -i ./src/styles/velas.css -o ./public/css/velas.min.css --minify",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/main.css -o ./public/css/main.css --minify",
    "build:js": "esbuild src/scripts/main.js --bundle --minify --sourcemap --target=chrome80,firefox78,safari14,edge90 --outfile=public/js/main.js",
    "build:js-velas": "esbuild src/scripts/velas.js --bundle --minify --sourcemap --target=chrome80,firefox78,safari14,edge90 --outfile=public/js/velas.js",
    "build:assets": "run-p copy:img copy:fonts copy:fa-css",
    "build": "run-s clean copy:html build:assets build:css build:css-velas build:js build:js-velas",
    "dev:css": "npx @tailwindcss/cli -i ./src/styles/main.css -o ./public/css/main.css --watch",
    "dev:js": "esbuild src/scripts/main.js --bundle --sourcemap --target=chrome80 --outfile=public/js/main.js --watch",
    "dev:js-velas": "esbuild src/scripts/velas.js --bundle --sourcemap --target=chrome80 --outfile=public/js/velas.js --watch",
    "dev": "run-s build && run-p dev:css dev:js dev:js-velas",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "check": "run-s format:check lint"
  },
  "keywords": [
    "website",
    "ivana-academy",
    "ivana-lerea",
    "ivana-courses",
    "devcontainer",
    "landing-pages",
    "frontend"
  ],
  "homepage": "https://leonardodg.github.io/courses-landing-pages/",
  "author": "LeonardoDG",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/cli": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "copyfiles": "^2.4.1",
    "del-cli": "^6.0.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.2.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^4.1.6"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "devicon": "^2.16.0",
    "material-icons": "^1.13.14"
  }
}